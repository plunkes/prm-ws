Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Status1
        - /Grid1
        - /RobotModel1/Description Topic1
        - /LaserScan1/Topic1
        - /Map1
        - /Path1
      Splitter Ratio: 0.5
    Tree Height: 182
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
